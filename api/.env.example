PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
# On Vercel, prefer one of these instead of a file path:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# AES_256_SECRET_KEY_HEX=64_hex_characters_here
# FIREBASE_SERVICE_ACCOUNT_JSON_AES256=base64(iv):base64(tag):base64(ciphertext)

STORAGE_PROVIDER=vercel-blob
STORAGE_ACCESS=public
# Vercel usually adds this automatically after you connect a Blob store:
BLOB_READ_WRITE_TOKEN=
# Optional generic alias or AES-256-GCM encrypted alternative:
# STORAGE_READ_WRITE_TOKEN=vercel_blob_rw_xxx
# STORAGE_READ_WRITE_TOKEN_AES256=base64(iv):base64(tag):base64(ciphertext)

# Vercel Functions accept request bodies up to 4.5 MB, so keep this at 4 or lower.
MAX_UPLOAD_SIZE_MB=4
