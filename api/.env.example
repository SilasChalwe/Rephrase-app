PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

STORAGE_PROVIDER=vercel-blob
STORAGE_ACCESS=public
# Vercel Blob token name from Vercel:
BLOB_READ_WRITE_TOKEN=
# Optional shorter alias if you prefer:
_READ_WRITE_TOKEN=

# Vercel Functions accept request bodies up to 4.5 MB, so keep this at 4 or lower.
MAX_UPLOAD_SIZE_MB=4
